generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Wine {
  id             String      @id @default(uuid())
  name           String
  slug           String      @unique
  vintage        Int
  wineryId       String
  regionId       String
  country        String
  grapeVarieties Json
  alcoholPercent Float
  description    String
  imageUrl       String
  squareItemId   String?     @unique
  createdAt      DateTime    @default(now())

  winery    Winery           @relation(fields: [wineryId], references: [id], onDelete: Restrict)
  region    Region           @relation(fields: [regionId], references: [id], onDelete: Restrict)
  variations WineVariation[]
  ratings   Rating[]

  @@unique([name, wineryId, vintage])
  @@index([regionId])
  @@index([wineryId])
}

model WineVariation {
  id                  String    @id @default(uuid())
  wineId              String
  squareVariationId   String?
  name                String
  price               Decimal   @db.Decimal(10, 2)
  volumeOz            Int?
  isPublic            Boolean   @default(true)
  isDefault           Boolean   @default(false)
  createdAt           DateTime  @default(now())

  wine      Wine        @relation(fields: [wineId], references: [id], onDelete: Cascade)
  inventory Inventory[]

  @@index([wineId])
  @@index([squareVariationId])
}

model Winery {
  id          String @id @default(uuid())
  name        String
  regionId    String
  country     String
  website     String
  description String

  region Region @relation(fields: [regionId], references: [id], onDelete: Restrict)
  wines  Wine[]

  @@index([regionId])
}

model Region {
  id       String  @id @default(uuid())
  name     String
  parentId String?

  parent   Region?  @relation("RegionHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Region[] @relation("RegionHierarchy")
  wines    Wine[]
  wineries Winery[]

  @@index([parentId])
}

model Inventory {
  id                String   @id @default(uuid())
  wineVariationId   String
  locationId        String
  stockQuantity     Int
  isAvailable       Boolean  @default(true)
  isFeatured        Boolean  @default(false)
  createdAt         DateTime @default(now())

  wineVariation WineVariation @relation(fields: [wineVariationId], references: [id], onDelete: Cascade)

  @@index([wineVariationId])
  @@unique([wineVariationId, locationId])
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())

  ratings Rating[]
}

model Rating {
  id        String   @id @default(uuid())
  userId    String
  wineId    String
  rating    Int
  notes     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  wine Wine @relation(fields: [wineId], references: [id], onDelete: Cascade)

  @@index([wineId])
  @@index([userId])
}
